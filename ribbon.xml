<customUI xmlns="http://schemas.microsoft.com/office/2006/01/customui" onLoad="OnAddinLoad">
    <ribbon startFromScratch="false">
        <tabs>
            <tab id="zoteroTab" getLabel="GetLabel" keytip="C">
                <group id="zoteroGroup" getLabel="GetLabel">
                    <button id="btnAddEditCitation" getLabel="GetLabel" onAction="OnAction" getImage="GetImage" getSupertip="GetSupertip" visible="true" size="large" keytip="C"/>
                    <button id="btnAddEditBib"      getLabel="GetLabel" onAction="OnAction" getImage="GetImage" getSupertip="GetSupertip" visible="true" size="large" keytip="B"/>
                    <button id="btnRefresh"         getLabel="GetLabel" onAction="OnAction" getImage="GetImage" getSupertip="GetSupertip" visible="true" size="large" keytip="R"/>
                    <button id="btnPref"            getLabel="GetLabel" onAction="OnAction" getImage="GetImage" getSupertip="GetSupertip" visible="true"             keytip="P"/>
                    <button id="btnAddNote"         getLabel="GetLabel" onAction="OnAction" getImage="GetImage" getSupertip="GetSupertip" visible="true"             keytip="N"/>
                    <button id="btnUnlink"          getLabel="GetLabel" onAction="OnAction" getImage="GetImage" getSupertip="GetSupertip" visible="true"             keytip="U"/>
                    <button id="btnExport"          getLabel="GetLabel" onAction="OnAction" getImage="GetImage" getSupertip="GetSupertip" visible="true"             keytip="E"/>
                    <button id="btnAbout"           getLabel="GetLabel" onAction="OnAction" getImage="GetImage" getSupertip="GetSupertip" visible="true" size="large" keytip="A"/>
                    <!-- Menú desplegable de idioma -->
                    <menu id="menuLang" getLabel="GetLabel" getImage="GetImage" getSupertip="GetSupertip" visible="true" keytip="L">
                        <button id="btnLangEn" label="English"  onAction="OnAction" getImage="GetImageLang" visible="true"/>
                        <button id="btnLangEs" label="Español"  onAction="OnAction" getImage="GetImageLang" visible="true"/>
                        <button id="btnLangZh" label="中文"      onAction="OnAction" getImage="GetImageLang" visible="true"/>
                    </menu>
                </group>
            </tab>
        </tabs>
    </ribbon>
</customUI>
